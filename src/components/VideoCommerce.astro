---
interface Props {
  previewUrl: string;
  videoUrls?: string[];
  fullUrl?: string; // Mantido por compatibilidade
  tooltipText?: string;
  positionClasses?: string;
  showCta?: boolean;
  ctaText?: string;
  ctaLink?: string;
  loop?: boolean;
  requireScrollOnMobile?: boolean;
}

const {
  previewUrl,
  videoUrls = [],
  fullUrl,
  tooltipText = "Veja como funciona",
  positionClasses = "fixed bottom-6 left-6 z-50",
  showCta = true,
  ctaText = "Testar grátis por 15 dias",
  ctaLink = "/cadastro",
  loop = false,
  requireScrollOnMobile = true,
} = Astro.props;

// Normaliza a lista de vídeos: prioriza array, depois usa fallback de string única
const activeVideos = videoUrls.length > 0 ? videoUrls : (fullUrl ? [fullUrl] : []);

// Gera um ID exclusivo para permitir múltiplas instâncias na mesma página sem conflitos
const uniqueId = `vc-${Math.random().toString(36).substring(2, 9)}`;
---

<div
  id={uniqueId}
  class={`${positionClasses} flex items-center select-none`}
  data-active-videos={JSON.stringify(activeVideos)}
  data-loop={loop ? "true" : "false"}
  data-require-scroll={requireScrollOnMobile ? "true" : "false"}
  style="z-index: 50;"
>
  {/* ── Widget Flutuante / Bolinha ── */}
  <div
    class="video-widget flex items-center cursor-grab active:cursor-grabbing transition-transform duration-300 opacity-0 pointer-events-none"
    style="transform: translateX(-100px);"
  >
    {/* Bolha de Vídeo */}
    <div
      class="video-bubble relative rounded-full overflow-hidden shadow-[0_8px_30px_rgb(0,0,0,0.3)] border-4 border-white transition-transform hover:scale-105 group w-[72px] h-[72px] sm:w-[84px] sm:h-[84px] flex-shrink-0 z-20 bg-black cursor-pointer"
      aria-label="Abrir vídeo"
    >
      <div class="absolute inset-0 bg-[#f59e0b] rounded-full animate-ping opacity-20 z-0 pointer-events-none"></div>
      <video
        src={previewUrl}
        autoplay
        loop
        muted
        playsinline
        class="w-full h-full object-cover relative z-10 pointer-events-none"
      />
    </div>

    {/* Tooltip / Legenda saindo de trás */}
    <div
      class="video-tooltip z-10 transition-[max-width,opacity,margin] duration-300 ease-out flex items-center overflow-hidden max-w-0 opacity-0 -ml-16"
    >
      <div
        class="bg-black/90 cursor-pointer text-white text-[10px] sm:text-[11px] uppercase font-bold pl-10 pr-5 py-3 rounded-r-full whitespace-nowrap shadow-xl tracking-widest border-y-2 border-r-2 border-white/10"
      >
        {tooltipText}
      </div>
    </div>
  </div>

  {/* ── Modal de Reprodução (Full Video Overlay) ── */}
  <div
    class="video-modal fixed inset-0 z-[99999] flex items-center justify-center bg-black/90 backdrop-blur-md p-0 md:p-8 opacity-0 pointer-events-none transition-opacity duration-300"
  >
    <div
      class="modal-card relative w-full h-full md:max-w-[420px] md:h-auto md:aspect-[9/16] bg-black md:rounded-[2rem] overflow-hidden shadow-2xl flex flex-col justify-center border border-white/10 group transition-all duration-300 scale-95 translate-y-4 opacity-0"
    >
      {/* Top Gradient para legibilidade dos Stories e Controles */}
      <div class="absolute top-0 left-0 right-0 h-32 bg-gradient-to-b from-black/80 to-transparent z-40 pointer-events-none"></div>

      {/* Ações do Topo & Barras de Stories */}
      <div class="absolute top-0 left-0 right-0 p-4 pt-5 z-50 pointer-events-none flex flex-col gap-3">
        {/* Barras de Progresso de Stories (Clicáveis para navegação direta) */}
        {activeVideos.length > 0 && (
          <div class="stories-progress-bars flex gap-1.5 w-full pointer-events-auto">
            {activeVideos.map((_, index) => (
              <div 
                class="story-bar-container h-3 flex items-center flex-1 cursor-pointer"
                data-index={index}
              >
                <div class="h-1 w-full bg-white/30 rounded-full overflow-hidden backdrop-blur-sm pointer-events-none">
                  <div 
                    class="story-bar-fill h-full bg-white rounded-full"
                    style="width: 0%;"
                  />
                </div>
              </div>
            ))}
          </div>
        )}

        <div class="flex justify-between items-center w-full">
          <button
            class="action-mute bg-black/30 hover:bg-black/60 text-white rounded-full p-2.5 backdrop-blur-md transition-all border border-white/10 pointer-events-auto active:scale-95"
            aria-label="Alternar som"
          >
            {/* Volume ON (Padrão) */}
            <svg class="icon-volume-on w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.54 8.46a5 5 0 0 1 0 7.07M19.07 4.93a10 10 0 0 1 0 14.14M11 5L6 9H2v6h4l5 4V5z" />
            </svg>
            {/* Volume MUTADO (Escondido por padrão) */}
            <svg class="icon-volume-mute w-5 h-5 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11 5L6 9H2v6h4l5 4V5zM23 9l-6 6m0-6l6 6" />
            </svg>
          </button>

          <button
            class="action-close bg-black/30 hover:bg-black/60 text-white rounded-full p-2.5 backdrop-blur-md transition-all border border-white/10 pointer-events-auto active:scale-95"
            aria-label="Fechar"
          >
            <svg class="w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>

      {/* Zonas de Toque para Navegação (Esquerda / PlayPause / Direita) */}
      <div class="absolute inset-0 z-40 flex touch-manipulation">
        {/* Voltar (Stories anterior) */}
        <div class="nav-zone-prev w-[30%] h-full cursor-pointer flex items-center justify-start group/navleft">
          {activeVideos.length > 1 && (
            <div class="hidden md:flex ml-4 w-10 h-10 rounded-full bg-black/20 backdrop-blur-sm items-center justify-center text-white/50 group-hover/navleft:bg-black/50 group-hover/navleft:text-white transition-all border border-white/5 opacity-0 group-hover:opacity-100 duration-300">
              <svg class="w-6 h-6 mr-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <polyline points="15 18 9 12 15 6" />
              </svg>
            </div>
          )}
        </div>

        {/* Play/Pause Central */}
        <div class="nav-zone-play w-[40%] h-full cursor-pointer flex items-center justify-center">
          <div class="play-state-overlay bg-black/50 backdrop-blur-md rounded-full p-5 text-white shadow-xl border border-white/10 opacity-0 scale-50 transition-all duration-300 pointer-events-none">
            <svg class="w-10 h-10 ml-0.5" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
              <path d="M8 5v14l11-7z" />
            </svg>
          </div>
        </div>

        {/* Avançar (Próximo Stories) */}
        <div class="nav-zone-next w-[30%] h-full cursor-pointer flex items-center justify-end group/navright">
          {activeVideos.length > 1 && (
            <div class="hidden md:flex mr-4 w-10 h-10 rounded-full bg-black/20 backdrop-blur-sm items-center justify-center text-white/50 group-hover/navright:bg-black/50 group-hover/navright:text-white transition-all border border-white/5 opacity-0 group-hover:opacity-100 duration-300">
              <svg class="w-6 h-6 ml-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <polyline points="9 18 15 12 9 6" />
              </svg>
            </div>
          )}
        </div>
      </div>

      {/* Elemento de Vídeo Real */}
      <video
        class="main-video w-full h-full object-contain bg-black"
        playsinline
      />

      {/* Bottom Gradient para legibilidade do CTA */}
      <div class="absolute bottom-0 left-0 right-0 h-48 bg-gradient-to-t from-black/90 to-transparent z-40 pointer-events-none"></div>

      {/* Área do CTA */}
      <div class="absolute bottom-0 left-0 right-0 z-50 flex flex-col px-6 pb-6 pointer-events-none">
        {showCta && (
          <a
            href={ctaLink}
            class="video-cta w-full bg-[#f59e0b] hover:bg-[#d97706] text-[#1a1a1a] font-bold py-4 rounded-xl shadow-[0_4px_20px_rgba(245,158,11,.4)] transition-all text-center text-[0.95rem] active:scale-[0.98] pointer-events-auto flex items-center justify-center gap-2"
          >
            {ctaText}
          </a>
        )}
      </div>
    </div>
  </div>
</div>

<script is:inline define:vars={{ uniqueId }}>
  (function() {
    const container = document.getElementById(uniqueId);
    if (!container) return;

    // Configurações e Arrays
    const activeVideos = JSON.parse(container.getAttribute('data-active-videos') || '[]');
    const loop = container.getAttribute('data-loop') === 'true';
    const requireScroll = container.getAttribute('data-require-scroll') === 'true';

    // Seleção de Elementos DOM Internos
    const widget = container.querySelector('.video-widget');
    const bubble = container.querySelector('.video-bubble');
    const tooltip = container.querySelector('.video-tooltip');
    const modal = container.querySelector('.video-modal');
    const card = container.querySelector('.modal-card');
    const video = container.querySelector('.main-video');
    const btnMute = container.querySelector('.action-mute');
    const iconVolumeOn = container.querySelector('.icon-volume-on');
    const iconVolumeMute = container.querySelector('.icon-volume-mute');
    const btnClose = container.querySelector('.action-close');
    const zonePrev = container.querySelector('.nav-zone-prev');
    const zoneNext = container.querySelector('.nav-zone-next');
    const zonePlay = container.querySelector('.nav-zone-play');
    const overlayPlay = container.querySelector('.play-state-overlay');
    const barFills = container.querySelectorAll('.story-bar-fill');
    const barContainers = container.querySelectorAll('.story-bar-container');

    // Estados do Player
    let isOpen = false;
    let isMuted = false;
    let currentIndex = 0;
    let isPlaying = true;
    let isDragging = false;
    let dragStartX = 0;
    let dragStartY = 0;
    let currentX = 0;
    let currentY = 0;
    let offsetX = 0;
    let offsetY = 0;
    let hasShownTooltip = false;
    
    // Id do requestAnimationFrame para animação ultra-suave a 60 FPS
    let animationFrameId = null;

    // ── Lógica de Visibilidade do Widget ──
    const showWidget = () => {
      widget.classList.remove('opacity-0', 'pointer-events-none');
      widget.style.transform = 'translate(0px, 0px)';
      
      // Delay suave para o Tooltip na primeira exibição
      if (!hasShownTooltip) {
        setTimeout(() => {
          tooltip.classList.remove('max-w-0', 'opacity-0', '-ml-16');
          tooltip.classList.add('max-w-[200px]', 'opacity-100', '-ml-6');
          hasShownTooltip = true;
        }, 800);
      }
    };

    const checkScrollVisibility = () => {
      if (!requireScroll || window.innerWidth >= 640) {
        showWidget();
        return;
      }

      // No mobile, só mostra após rolar 100px
      if (window.scrollY > 100) {
        showWidget();
      } else {
        widget.classList.add('opacity-0', 'pointer-events-none');
        widget.style.transform = 'translateX(-100px)';
      }
    };

    window.addEventListener('scroll', checkScrollVisibility, { passive: true });
    window.addEventListener('resize', checkScrollVisibility, { passive: true });
    checkScrollVisibility(); // Checagem inicial

    // ── Lógica do Drag (Arrastar apenas a bolinha flutuante, preservando o modal centralizado!) ──
    const onDragStart = (e) => {
      isDragging = false;
      const clientX = e.type.startsWith('touch') ? e.touches[0].clientX : e.clientX;
      const clientY = e.type.startsWith('touch') ? e.touches[0].clientY : e.clientY;
      dragStartX = clientX - offsetX;
      dragStartY = clientY - offsetY;
      
      document.addEventListener('mousemove', onDragMove);
      document.addEventListener('mouseup', onDragEnd);
      document.addEventListener('touchmove', onDragMove, { passive: false });
      document.addEventListener('touchend', onDragEnd);
    };

    const onDragMove = (e) => {
      const clientX = e.type.startsWith('touch') ? e.touches[0].clientX : e.clientX;
      const clientY = e.type.startsWith('touch') ? e.touches[0].clientY : e.clientY;
      currentX = clientX - dragStartX;
      currentY = clientY - dragStartY;

      // Se arrastar mais de 5px, considera drag ativo
      if (Math.abs(currentX - offsetX) > 5 || Math.abs(currentY - offsetY) > 5) {
        isDragging = true;
      }

      offsetX = currentX;
      offsetY = currentY;
      
      // Move o widget da bolinha (e não o container inteiro!)
      widget.style.transform = `translate(${offsetX}px, ${offsetY}px)`;
      
      if (e.cancelable) e.preventDefault();
    };

    const onDragEnd = () => {
      document.removeEventListener('mousemove', onDragMove);
      document.removeEventListener('mouseup', onDragEnd);
      document.removeEventListener('touchmove', onDragMove);
      document.removeEventListener('touchend', onDragEnd);
    };

    bubble.addEventListener('mousedown', onDragStart);
    bubble.addEventListener('touchstart', onDragStart, { passive: true });

    // Abrir o modal
    const openModal = () => {
      if (isDragging) return; // Se foi drag, não abre

      isOpen = true;
      currentIndex = 0;
      isPlaying = true;
      isMuted = false;

      // Restaura ícones de som
      video.muted = false;
      iconVolumeOn.classList.remove('hidden');
      iconVolumeMute.classList.add('hidden');

      // Exibe modal com transição de escala e translação Y suaves
      modal.classList.remove('opacity-0', 'pointer-events-none');
      card.classList.remove('scale-95', 'translate-y-4', 'opacity-0');
      card.classList.add('scale-100', 'translate-y-0', 'opacity-100');

      loadVideo(0);
    };

    bubble.addEventListener('click', openModal);
    tooltip.addEventListener('click', openModal);

    // Fechar o modal
    const closeModal = () => {
      isOpen = false;
      video.pause();
      
      // Para o requestAnimationFrame de progresso
      if (animationFrameId) {
        cancelAnimationFrame(animationFrameId);
        animationFrameId = null;
      }
      
      modal.classList.add('opacity-0', 'pointer-events-none');
      card.classList.add('scale-95', 'translate-y-4', 'opacity-0');
      card.classList.remove('scale-100', 'translate-y-0', 'opacity-100');
    };

    btnClose.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });

    // ── Lógica de Animação 60FPS do Progresso (Instagram Stories-like) ──
    const updatePlayProgress = () => {
      if (!isOpen || video.paused || video.ended || !video.duration) {
        animationFrameId = null;
        return;
      }

      // Calcula porcentagem exata de tempo decorrido do vídeo
      const progress = (video.currentTime / video.duration) * 100;
      
      // Atualiza a largura da barra atual a cada frame de renderização do monitor (60 a 120 FPS)
      if (barFills[currentIndex]) {
        barFills[currentIndex].style.width = `${progress}%`;
      }

      // Agenda atualização para o próximo frame
      animationFrameId = requestAnimationFrame(updatePlayProgress);
    };

    // ── Lógica do Player & Stories ──
    const loadVideo = (index) => {
      if (!activeVideos[index]) return;
      
      // Cancela loop de frame anterior
      if (animationFrameId) {
        cancelAnimationFrame(animationFrameId);
        animationFrameId = null;
      }

      currentIndex = index;
      video.src = activeVideos[index];
      video.load();
      video.play().catch(() => {});
      isPlaying = true;
      overlayPlay.classList.add('opacity-0', 'scale-50', 'pointer-events-none');
      overlayPlay.classList.remove('opacity-100', 'scale-100');
      updateProgressBars();
      
      // Inicia loop de renderização ultra-suave
      animationFrameId = requestAnimationFrame(updatePlayProgress);
    };

    // Avançar (Stories/Vídeo seguinte)
    const handleNext = () => {
      if (currentIndex < activeVideos.length - 1) {
        loadVideo(currentIndex + 1);
      } else {
        // Chegou ao fim da lista de vídeos, volta ao início (comportamento de loop infinito do Stories)
        loadVideo(0);
      }
    };

    // Voltar (Stories/Vídeo anterior)
    const handlePrev = () => {
      if (currentIndex > 0) {
        loadVideo(currentIndex - 1);
      } else {
        video.currentTime = 0;
        if (barFills[0]) barFills[0].style.width = '0%';
      }
    };

    // Atualiza barras superiores do stories
    const updateProgressBars = () => {
      barFills.forEach((bar, idx) => {
        if (idx < currentIndex) {
          bar.style.width = '100%';
        } else if (idx > currentIndex) {
          bar.style.width = '0%';
        }
      });
    };

    video.addEventListener('play', () => {
      if (!animationFrameId) {
        animationFrameId = requestAnimationFrame(updatePlayProgress);
      }
    });

    video.addEventListener('pause', () => {
      if (animationFrameId) {
        cancelAnimationFrame(animationFrameId);
        animationFrameId = null;
      }
    });

    video.addEventListener('ended', handleNext);

    // Play/Pause Central
    const togglePlay = () => {
      if (isPlaying) {
        video.pause();
        isPlaying = false;
        overlayPlay.classList.remove('opacity-0', 'scale-50', 'pointer-events-none');
        overlayPlay.classList.add('opacity-100', 'scale-100');
      } else {
        video.play().catch(() => {});
        isPlaying = true;
        overlayPlay.classList.add('opacity-0', 'scale-50', 'pointer-events-none');
        overlayPlay.classList.remove('opacity-100', 'scale-100');
      }
    };

    zonePlay.addEventListener('click', togglePlay);

    // Mute/Unmute
    btnMute.addEventListener('click', () => {
      isMuted = !isMuted;
      video.muted = isMuted;
      
      if (isMuted) {
        iconVolumeOn.classList.add('hidden');
        iconVolumeMute.classList.remove('hidden');
      } else {
        iconVolumeOn.classList.remove('hidden');
        iconVolumeMute.classList.add('hidden');
      }
    });

    // Cliques nas laterais
    zonePrev.addEventListener('click', (e) => {
      e.stopPropagation();
      handlePrev();
    });

    zoneNext.addEventListener('click', (e) => {
      e.stopPropagation();
      handleNext();
    });

    // Cliques nas barras superiores para navegar direto para o story correspondente (Instagram Stories-like)
    barContainers.forEach((barContainer) => {
      barContainer.addEventListener('click', (e) => {
        e.stopPropagation(); // Previne propagação de clique que pausaria o vídeo
        const targetIdx = parseInt(barContainer.getAttribute('data-index') || '0', 10);
        
        // Se clicar no story em que já se encontra, ignora (não recomeça o vídeo)
        if (targetIdx !== currentIndex) {
          loadVideo(targetIdx);
        }
      });
    });
  })();
</script>
