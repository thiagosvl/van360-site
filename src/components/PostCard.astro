---
import type { BlogPost } from "../utils/api";
import { Calendar, Eye, Clock } from "@lucide/astro";

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

// Formatting date
const formattedDate = post.published_at
  ? new Date(post.published_at).toLocaleDateString("pt-BR", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    })
  : new Date(post.created_at).toLocaleDateString("pt-BR", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    });
---

<article class="group bg-white rounded-3xl border border-slate-100 p-6 flex flex-col justify-between shadow-diff-shadow hover:translate-y-[-4px] hover:border-slate-200 transition-all duration-300">
  <div class="space-y-4">
    {/* Tags */}
    <div class="flex flex-wrap gap-1.5">
      {post.tags.map((tag) => (
        <a
          href={`/tags/${tag}`}
          class="text-[10px] font-bold uppercase tracking-wider text-brand-blue bg-brand-blue/5 hover:bg-brand-blue/10 px-2.5 py-1 rounded-lg transition-colors"
        >
          {tag}
        </a>
      ))}
    </div>

    {/* Title & Excerpt */}
    <div class="space-y-2 text-left">
      <a href={`/blog/${post.slug}`} class="block">
        <h3 class="text-lg font-bold text-slate-800 font-headline group-hover:text-brand-blue transition-colors line-clamp-2 leading-tight">
          {post.title}
        </h3>
      </a>
      <p class="text-sm text-slate-500 line-clamp-3 leading-relaxed">
        {post.excerpt}
      </p>
    </div>
  </div>

  {/* Footer Metadata */}
  <div class="border-t border-slate-50 mt-6 pt-4 flex items-center justify-between text-xs text-slate-400 font-semibold uppercase tracking-wider">
    <div class="flex items-center gap-1.5">
      <Calendar class="h-3.5 w-3.5" />
      <span>{formattedDate}</span>
    </div>
    <div class="flex items-center gap-3">
      <div class="flex items-center gap-1">
        <Eye class="h-3.5 w-3.5" />
        <span>{post.views}</span>
      </div>
    </div>
  </div>
</article>
