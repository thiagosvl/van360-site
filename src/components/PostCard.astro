---
import type { BlogPost } from "../utils/api";
import { Calendar } from "@lucide/astro";
import { Image } from "astro:assets";

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

// Formatting date
const formattedDate = post.published_at
  ? new Date(post.published_at).toLocaleDateString("pt-BR", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    })
  : new Date(post.created_at).toLocaleDateString("pt-BR", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    });
---

<article class="group bg-white rounded-3xl border border-slate-100 flex flex-col justify-between overflow-hidden shadow-diff-shadow hover:translate-y-[-6px] hover:shadow-lg hover:border-slate-200/80 transition-all duration-300 h-full">
  <div>
    {/* Image / Gradient Placeholder */}
    <a href={`/blog/${post.slug}`} class="block overflow-hidden relative aspect-video bg-slate-50 border-b border-slate-100">
      {post.cover_image_url ? (
        <Image
          src={post.cover_image_url}
          alt={post.title}
          width={400}
          height={225}
          format="webp"
          loading="lazy"
          class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500 ease-out"
        />
      ) : (
        <div class="w-full h-full bg-gradient-to-tr from-brand-blue to-blue-950 flex items-center justify-center p-6 relative">
          <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-yellow-400/10 via-transparent to-transparent"></div>
          <span class="text-2xl font-headline font-black text-white/10 tracking-widest uppercase select-none group-hover:scale-[1.05] transition-transform duration-500">
            Van360
          </span>
        </div>
      )}
    </a>

    <div class="p-6 space-y-4">
      {/* Tags */}
      <div class="flex flex-wrap gap-1.5">
        {post.tags.map((tag) => (
          <a
            href={`/tags/${tag}`}
            class="text-[10px] font-bold uppercase tracking-wider text-brand-blue bg-brand-blue/5 hover:bg-brand-blue/10 px-2.5 py-1 rounded-lg transition-colors"
          >
            {tag}
          </a>
        ))}
      </div>

      {/* Title & Excerpt */}
      <div class="space-y-2 text-left">
        <a href={`/blog/${post.slug}`} class="block">
          <h3 class="text-lg font-bold text-slate-800 font-headline group-hover:text-brand-blue transition-colors line-clamp-2 leading-tight">
            {post.title}
          </h3>
        </a>
        <p class="text-sm text-slate-500 line-clamp-3 leading-relaxed">
          {post.excerpt}
        </p>
      </div>
    </div>
  </div>

  {/* Footer Metadata */}
  <div class="px-6 pb-6 pt-4 flex items-center justify-between text-xs text-slate-400 font-semibold uppercase tracking-wider">
    <div class="flex items-center gap-1.5">
      <Calendar class="h-3.5 w-3.5 text-slate-400" />
      <span>{formattedDate}</span>
    </div>
    
    <a href={`/blog/${post.slug}`} class="text-[10px] font-black text-brand-blue hover:text-brand-blue/80 flex items-center gap-1 transition-colors group-hover:translate-x-1 duration-300">
      Ler Artigo
      <span class="text-xs">&rarr;</span>
    </a>
  </div>
</article>
