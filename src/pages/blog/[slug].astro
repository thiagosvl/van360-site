---
import BlogLayout from "../../layouts/BlogLayout.astro";
import HeaderBlog from "../../components/HeaderBlog.astro";
import Footer from "../../components/Footer.astro";
import CtaBanner from "../../components/CtaBanner.astro";
import { blogApi } from "../../utils/api";
import { Calendar, ArrowLeft } from "@lucide/astro";
import PostCard from "../../components/PostCard.astro";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const { posts } = await blogApi.getBlogPosts(1, 100);
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = await blogApi.getBlogPostDetails(slug);

// Fetch recommended posts (recent ones excluding current)
const { posts: allPosts } = await blogApi.getBlogPosts(1, 4);
const recommendedPosts = allPosts
  .filter((p) => p.slug !== slug)
  .slice(0, 3);

const formattedDate = post.published_at
  ? new Date(post.published_at).toLocaleDateString("pt-BR", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    })
  : new Date(post.created_at).toLocaleDateString("pt-BR", {
      day: "2-digit",
      month: "long",
      year: "numeric",
    });

// Process content to insert CTAs dynamically on server-side
const ctaPlaceholder = '<div data-cta="signup-driver-banner"></div>';
const contentParts = post.content.split(ctaPlaceholder);

// Schema.org BlogPosting metadata for rich snippets
const schemaJson = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.excerpt || post.title,
  "datePublished": post.published_at || post.created_at,
  "dateModified": post.published_at || post.created_at,
  "author": {
    "@type": "Organization",
    "name": "Van360",
    "url": "https://van360.com.br"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Van360",
    "logo": {
      "@type": "ImageObject",
      "url": "https://van360.com.br/assets/logo-van360.png"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://van360.com.br/blog/${post.slug}`
  }
});
---

<BlogLayout title={post.title} description={post.excerpt || undefined}>
  <script type="application/ld+json" slot="head" set:html={schemaJson} />
  <HeaderBlog />

  <main class="flex-1 py-12 px-4 sm:px-6 lg:px-8 max-w-4xl mx-auto w-full space-y-8 mt-14 md:mt-16">
    {/* Breadcrumbs / Back button */}
    <div class="flex items-center justify-between">
      <a href="/blog" class="text-xs font-bold text-slate-500 hover:text-brand-blue flex items-center gap-2 transition-colors uppercase tracking-wider">
        <ArrowLeft class="h-4 w-4" />
        Voltar para os Artigos
      </a>
    </div>

    {/* Post Header */}
    <header class="space-y-6 text-left">
      <div class="flex flex-wrap gap-2">
        {post.tags.map((tag) => (
          <a
            href={`/tags/${tag}`}
            class="text-[10px] font-bold uppercase tracking-wider text-brand-blue bg-brand-blue/5 hover:bg-brand-blue/10 px-3 py-1 rounded-lg transition-colors"
          >
            {tag}
          </a>
        ))}
      </div>

      <h1 class="text-2xl sm:text-4xl font-headline font-black text-brand-blue tracking-tight leading-tight">
        {post.title}
      </h1>

      {/* Meta */}
      <div class="flex flex-wrap items-center gap-6 text-xs text-slate-400 font-semibold uppercase tracking-wider pt-2 border-y border-slate-100 py-3">
        <div class="flex items-center gap-1.5">
          <Calendar class="h-4 w-4" />
          <span>Publicado em {formattedDate}</span>
        </div>
      </div>
    </header>

    {/* Cover Image */}
    {post.cover_image_url && (
      <div class="aspect-video w-full overflow-hidden rounded-3xl border border-slate-100 shadow-md">
        <Image
          src={post.cover_image_url}
          alt={post.title}
          width={800}
          height={450}
          format="webp"
          class="w-full h-full object-cover"
        />
      </div>
    )}

    {/* Article Content */}
    <article class="bg-white rounded-3xl border border-slate-100 p-6 sm:p-10 shadow-diff-shadow">
      {contentParts.map((part, idx) => (
        <Fragment>
          <div 
            class="prose prose-slate max-w-none text-left prose-headings:font-headline prose-headings:font-black prose-headings:text-brand-blue prose-h2:text-xl prose-h3:text-lg prose-p:text-sm prose-p:leading-relaxed prose-blockquote:border-l-4 prose-blockquote:border-yellow-500 prose-blockquote:bg-slate-50/50 prose-blockquote:text-slate-700 prose-blockquote:italic prose-blockquote:py-2 prose-blockquote:px-4 prose-blockquote:rounded-r-xl prose-blockquote:not-italic prose-blockquote:font-medium prose-img:rounded-2xl prose-img:shadow-md"
            set:html={part} 
          />
          {idx < contentParts.length - 1 && (
            <div class="my-8">
              <CtaBanner />
            </div>
          )}
        </Fragment>
      ))}
    </article>

    {/* Recommended Posts Section */}
    {recommendedPosts.length > 0 && (
      <section class="space-y-6 border-t border-slate-100 pt-12 text-left">
        <h3 class="text-lg font-headline font-black text-brand-blue tracking-tight uppercase">
          Confira também outros artigos
        </h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {recommendedPosts.map((recommendedPost) => (
            <PostCard post={recommendedPost} />
          ))}
        </div>
      </section>
    )}
  </main>

  <Footer isBlog={true} />
</BlogLayout>

<style is:global>
  /* Global styles for TipTap rendered tables on mobile screens */
  .prose table {
    display: block;
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-collapse: collapse;
    margin: 1.5rem 0;
  }
  .prose th, .prose td {
    border: 1px border-slate-200;
    padding: 0.75rem;
    text-align: left;
    font-size: 0.875rem;
  }
  .prose th {
    background-color: #f8fafc;
    font-weight: 700;
    color: #1a3a5c;
  }
</style>
