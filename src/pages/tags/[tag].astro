---
import BlogLayout from "../../layouts/BlogLayout.astro";
import HeaderBlog from "../../components/HeaderBlog.astro";
import Footer from "../../components/Footer.astro";
import PostCard from "../../components/PostCard.astro";
import CtaBanner from "../../components/CtaBanner.astro";
import { blogApi } from "../../utils/api";
import type { BlogPost } from "../../utils/api";
import { ArrowLeft, Tag } from "@lucide/astro";

export async function getStaticPaths() {
  const { posts } = await blogApi.getBlogPosts(1, 100);
  const tags = Array.from(new Set(posts.flatMap((p) => p.tags)));
  return tags.map((tag) => ({
    params: { tag },
    props: { 
      posts: posts.filter((p) => p.tags.includes(tag)),
      allTags: tags
    },
  }));
}

interface Props {
  posts: BlogPost[];
  allTags: string[];
}

const { tag } = Astro.params;
const { posts, allTags } = Astro.props;
---

<BlogLayout title={`Assunto: ${tag}`}>
  <HeaderBlog />

  <main class="flex-1 py-12 px-4 sm:px-6 lg:px-8 max-w-7xl mx-auto w-full space-y-12 mt-14 md:mt-16">
    <div class="flex items-center text-left">
      <a href="/blog" class="text-xs font-bold text-slate-500 hover:text-brand-blue flex items-center gap-2 transition-colors uppercase tracking-wider">
        <ArrowLeft class="h-4 w-4" />
        Voltar para os Artigos
      </a>
    </div>

    {/* Hero Section */}
    <section class="text-center max-w-2xl mx-auto space-y-4">
      <div class="h-12 w-12 bg-brand-blue/5 border border-brand-blue/10 rounded-2xl flex items-center justify-center mx-auto text-brand-blue">
        <Tag class="h-6 w-6" />
      </div>
      <h2 class="text-2xl sm:text-3xl font-headline font-black text-brand-blue tracking-tight uppercase">
        Artigos sobre: <span class="text-purple-600">#{tag}</span>
      </h2>
      <p class="text-sm text-slate-500 font-semibold uppercase tracking-wider">
        {posts.length} artigo{posts.length !== 1 ? "s" : ""} encontrado{posts.length !== 1 ? "s" : ""}
      </p>
    </section>

    {/* Tags Selector / Filter pills */}
    <section class="flex flex-wrap items-center justify-center gap-2 max-w-3xl mx-auto">
      <span class="text-[9px] font-black text-slate-400 uppercase tracking-wider mr-2">Filtrar por:</span>
      <a
        href="/blog"
        class="text-xs font-bold px-3 py-1.5 rounded-full bg-white border border-slate-200 text-slate-600 hover:border-slate-300 hover:bg-slate-50 transition-all"
      >
        Todos
      </a>
      {allTags.map((t) => (
        <a
          href={`/tags/${t}`}
          class={`text-xs font-bold px-3 py-1.5 rounded-full transition-all ${
            t === tag
              ? "bg-brand-blue text-white shadow-md shadow-brand-blue/10"
              : "bg-white border border-slate-200 text-slate-600 hover:border-slate-300 hover:bg-slate-50"
          }`}
        >
          {t}
        </a>
      ))}
    </section>

    {/* Posts Grid */}
    <section class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {posts.map((post) => (
        <PostCard post={post} />
      ))}
    </section>

    {/* CTA middle block */}
    <section class="max-w-4xl mx-auto">
      <CtaBanner />
    </section>
  </main>

  <Footer />
</BlogLayout>
