<script is:inline>
  // ── Scroll Reveal Vanilla implementation ──
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("lp-visible");
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.05, rootMargin: "0px 0px -40px 0px" },
  );

  document.querySelectorAll(".lp-reveal").forEach((el) => {
    observer.observe(el);
  });

  // ── FAQ Accordion Vanilla implementation ──
  document.querySelectorAll(".faq-button").forEach((button) => {
    button.addEventListener("click", () => {
      const content = button.nextElementSibling;
      const icon = button.querySelector(".faq-icon");
      const isOpen = button.getAttribute("aria-expanded") === "true";

      // Close all other FAQs first to be clean
      document.querySelectorAll(".faq-button").forEach((otherBtn) => {
        if (
          otherBtn !== button &&
          otherBtn.getAttribute("aria-expanded") === "true"
        ) {
          otherBtn.setAttribute("aria-expanded", "false");
          otherBtn.nextElementSibling.style.maxHeight = "0px";
          otherBtn.querySelector(".faq-icon").classList.remove("rotate-180");
        }
      });

      button.setAttribute("aria-expanded", !isOpen ? "true" : "false");
      if (!isOpen) {
        content.style.maxHeight = content.scrollHeight + "px";
        icon.classList.add("rotate-180");
      } else {
        content.style.maxHeight = "0px";
        icon.classList.remove("rotate-180");
      }
    });
  });

  // ── Platform tailored UI implementation ──
  const isIOS = /iPhone|iPad/i.test(navigator.userAgent);
  const isMobile = window.matchMedia("(max-width: 768px)").matches || isIOS;

  if (isMobile) {
    if (isIOS) {
      document.getElementById("badge-ios-mobile")?.classList.remove("hidden");
      document.getElementById("badge-ios-cta")?.classList.remove("hidden");
    } else {
      document
        .getElementById("badge-android-mobile")
        ?.classList.remove("hidden");
      document.getElementById("badge-android-cta")?.classList.remove("hidden");
    }
  } else {
    // Desktop: show Android badge on final CTA as fallback
    document.getElementById("badge-android-cta")?.classList.remove("hidden");
  }

  // ── Cookie Consent Banner Vanilla implementation ──
  const COOKIE_NAME = "van360_cookie_consent";
  const banner = document.getElementById("cookie-banner");
  const waBtn = document.getElementById("floating-whatsapp");

  const updateBodyPadding = () => {
    if (!banner || banner.classList.contains("hidden")) return;
    const padding = window.innerWidth < 640 ? "68px" : "56px";
    document.body.style.paddingBottom = padding;
    if (waBtn) {
      waBtn.style.bottom = window.innerWidth < 640 ? "84px" : "72px";
    }
  };

  const hideBanner = () => {
    if (banner) banner.classList.add("hidden");
    document.body.style.paddingBottom = "";
    if (waBtn) waBtn.style.bottom = "20px";
  };

  const getCookie = (name) => {
    const value = `; ${document.cookie}`;
    const parts = value.split(`; ${name}=`);
    if (parts.length === 2) return parts.pop().split(";").shift();
    return null;
  };

  const setCookie = (name, value, days) => {
    const d = new Date();
    d.setTime(d.getTime() + days * 24 * 60 * 60 * 1000);
    document.cookie = `${name}=${value};expires=${d.toUTCString()};path=/`;
  };

  // Check consent
  if (!getCookie(COOKIE_NAME)) {
    if (banner) banner.classList.remove("hidden");
    updateBodyPadding();
    window.addEventListener("resize", updateBodyPadding);
  }

  document
    .getElementById("cookie-btn-accept")
    ?.addEventListener("click", () => {
      setCookie(COOKIE_NAME, "accepted", 365);
      hideBanner();
    });

  document
    .getElementById("cookie-btn-reject")
    ?.addEventListener("click", () => {
      setCookie(COOKIE_NAME, "rejected", 365);
      hideBanner();
    });

  document
    .getElementById("cookie-btn-customize")
    ?.addEventListener("click", () => {
      setCookie(COOKIE_NAME, "accepted", 365);
      hideBanner();
    });
</script>
