---
import Layout from "../layouts/Layout.astro";
import { LINKS } from "../constants/links";
import HeaderLP from "../components/HeaderLP.astro";
import Footer from "../components/Footer.astro";
import { blogApi } from "../utils/api";
import VideoCommerce from "../components/VideoCommerce.astro";
import { Image } from "astro:assets";
import {
  Users,
  Clock,
  Smartphone,
  Star,
  ChevronDown,
  Check,
  CheckCircle2,
} from "@lucide/astro";

// Imports de imagens para otimização pelo Astro
import mockup3dHome from "../assets/lp/mockup-3d-home.webp";
import mockup3dMensalidades from "../assets/lp/mockup-3d-mensalidades.webp";
import mockupMensalidades from "../assets/lp/mockup-mensalidades.webp";
import mockupPassageiros from "../assets/lp/mockup-passageiros.webp";
import mockupCarteirinha from "../assets/lp/mockup-carteirinha.webp";
import mockupRecibo from "../assets/lp/mockup-recibo.webp";
import mockupContrato from "../assets/lp/mockup-contrato.webp";
import mockupGastos from "../assets/lp/mockup-gastos.webp";
import mockupRelatorios from "../assets/lp/mockup-relatorios.webp";

// Fetch dynamic plans for pre-rendering
const plansData = await blogApi.getPublicPlans();

// Formatter helper
const formatCurrency = (val: number) => {
  return new Intl.NumberFormat("pt-BR", {
    style: "currency",
    currency: "BRL",
  }).format(val);
};

const isPromoActive = plansData.isPromotionActive;
const monthlyPlan = plansData.plans.find((p) => p.identificador === "MONTHLY");
const yearlyPlan = plansData.plans.find((p) => p.identificador === "YEARLY");

// Se os planos vitais não existirem no banco, dispara erro para interromper o build imediatamente
if (!monthlyPlan) {
  throw new Error("[Astro Build] Falha de integridade: Plano mensal ('MONTHLY') não foi retornado pelo banco de dados.");
}
if (!yearlyPlan) {
  throw new Error("[Astro Build] Falha de integridade: Plano anual ('YEARLY') não foi retornado pelo banco de dados.");
}

// Lógica de preços direta sem fallbacks codificados no frontend
const monthlyNormalVal = monthlyPlan.valor;
const originalVal = isPromoActive
  ? (monthlyPlan.valor_promocional ?? monthlyPlan.valor)
  : monthlyPlan.valor;

const yearlyTotalVal = isPromoActive
  ? (yearlyPlan.valor_promocional ?? yearlyPlan.valor)
  : yearlyPlan.valor;

const originalFormatted = formatCurrency(originalVal).replace("R$", "").trim();
const monthlyNormalFormatted = formatCurrency(monthlyNormalVal)
  .replace("R$", "")
  .trim();
const yearlyTotalFormatted = formatCurrency(yearlyTotalVal)
  .replace("R$", "")
  .trim();



const planFeatures = [
  "Lembretes de cobrança aos pais via WhatsApp",
  "Recibos gerados automaticamente",
  "Contratos digitais ilimitados",
  "Link de cadastro fácil para os pais",
  "Passageiros e vans sem limite",
  "Controle de gastos e finanças",
  "Alerta de aniversariantes",
  "Acesso no celular e computador",
  "Suporte direto no WhatsApp",
];

const features = [
  {
    headline: "Pare de cobrar os pais e de passar constrangimento",
    text: "Chega de ser 'o chato da cobrança'. O Van360 envia lembretes amigáveis pelo WhatsApp automaticamente. Saiba na hora quais parcelas foram pagas e quais ainda estão pendentes. O dinheiro entra e você só foca na direção.",
    mockup: mockupMensalidades,
    alt: "Painel de controle de parcelas pendentes e pagas da van escolar",
    balloonText: "A parcela de julho da Júlia vence amanhã.",
  },
  {
    headline: "Receba a ficha dos passageiros pronta",
    text: "Perder horas anotando nome, escola e endereço à mão? Nunca mais. Mande seu link exclusivo pelo WhatsApp e deixe os pais preencherem. Sua lista se organiza sozinha em segundos.",
    mockup: mockupPassageiros,
    alt: "Lista de passageiros organizados no aplicativo Van360",
    balloonText: "Pai, segue o link para matricular o aluno na van.",
  },
  {
    headline: "Diga adeus à velha carteirinha de papel",
    text: "Tenha a ficha completa dos alunos na palma da mão, direto na van. Chega de depender de carnês e fichas de papel. Segurança para você, profissionalismo para os pais.",
    mockup: mockupCarteirinha,
    alt: "Carteirinha digital do estudante na van",
  },
  {
    headline: "Envie recibos profissionais com poucos toques",
    text: "Confirmou o pagamento? O Van360 gera um recibo em PDF impecável e você envia direto no WhatsApp do responsável. Mostre que o seu serviço de transporte é de alto nível.",
    mockup: mockupRecibo,
    alt: "Recibo de pagamento gerado automaticamente pelo Van360",
    balloonText: "Seu recibo de pagamento já está disponível.",
  },
  {
    headline: "Acabou a papelada: Contratos digitais em 1 minuto",
    text: "Evite dor de cabeça com 'combinados de boca'. Gere contratos com validade jurídica e envie para o responsável assinar na tela do próprio celular dele. 100% seguro e digital.",
    mockup: mockupContrato,
    alt: "Assinatura de contrato digital no celular",
    balloonText: "O contrato de transporte foi assinado com sucesso.",
  },
  {
    headline: "Saiba exatamente para onde vai o seu dinheiro",
    text: "Combustível, troca de óleo, mecânico... Registre cada centavo gasto com a van. Pare de misturar o dinheiro da sua vida pessoal com o do seu negócio.",
    mockup: mockupGastos,
    alt: "Tela de controle de gastos e despesas da van escolar",
  },
  {
    headline: "Descubra se a sua van realmente está dando lucro",
    text: "Chega de fechar o mês no escuro. Tenha um painel que calcula automaticamente seu faturamento, suas despesas e o lucro líquido real. Comece a pensar como um dono de negócio.",
    mockup: mockupRelatorios,
    alt: "Relatórios financeiros detalhados para motoristas de van",
  },
];

const painPoints = [
  {
    icon: "📒",
    title: "Descontrole Financeiro",
    text: "Anota tudo no caderninho e no fim do mês não sabe o que entrou e o que não entrou.",
  },
  {
    icon: "⏰",
    title: "Trabalho Manual",
    text: "Perde horas conferindo pagamentos um a um na mão.",
  },
  {
    icon: "😤",
    title: "Combinados de Boca",
    text: "Gera estresse com os responsáveis porque os acordos não ficam registrados.",
  },
  {
    icon: "📱",
    title: "Sufoco no WhatsApp",
    text: "Gasta o seu tempo de descanso cobrando os pais e tirando dúvidas.",
  },
  {
    icon: "🧾",
    title: "Falta de Documentos",
    text: "Responsável pede recibo ou contrato e você não tem nada pronto para enviar.",
  },
  {
    icon: "💼",
    title: "Imagem Amadora",
    text: "Você trabalha duro, mas a falta de organização não passa profissionalismo.",
  },
];

const howItWorks = [
  {
    n: "1",
    title: "Crie sua conta grátis",
    desc: "Sem cartão, sem compromisso. Em segundos você faz seu cadastro.",
  },
  {
    n: "2",
    title: "Cadastre seus passageiros sem esforço",
    desc: "Mande um link pro pai pelo WhatsApp. Ele preenche os dados do filho e pronto — aparece na sua lista.",
  },
  {
    n: "3",
    title: "Pronto. Tudo organizado.",
    desc: "Parcelas, contratos e recibos — no seu celular.",
  },
];

const faqItems = [
  {
    q: "O que o Van360 faz?",
    a: "O Van360 organiza a gestão da sua van escolar: cadastro de passageiros, controle de parcelas, contratos digitais e emissão de recibos, geração de contratos digitais e emissão de recibos. Tudo pelo celular, em um lugar só.",
  },
  {
    q: "Preciso pagar para começar a utilizar?",
    a: "Não. Os 15 dias de teste são 100% grátis, sem cadastrar cartão, sem compromisso. Você usa tudo, com seus dados reais, e só decide depois.",
  },
  {
    q: "Onde posso usar o Van360?",
    a: "Em qualquer lugar. Funciona no navegador do celular, tablet ou computador — sem baixar nada. Se preferir, tem o app Android, que é leve e rápido. O Van360 funciona perfeitamente no iPhone através do navegador, e o app nativo já está em desenvolvimento.",
  },
  {
    q: "O que é a oferta/preço fundador?",
    a: `É o nosso preço de lançamento para os primeiros transportadores escolares que começarem a usar o Van360. Você paga R$ ${originalFormatted}/mês e mantém esse valor para sempre — mesmo quando o preço subir para quem entrar depois.`,
  },
  {
    q: "O contrato gerado tem validade jurídica?",
    a: "Sim. Os contratos são digitais e assinados eletronicamente, com validade legal conforme a legislação brasileira. Servem como documento formal entre você e o responsável do passageiro.",
  },
  {
    q: "O app é pesado? Preciso baixar?",
    a: "Não. O Van360 funciona na nuvem e pode ser usado pelo navegador sem ocupar espaço no seu celular. Se preferir o aplicativo Android, ele pesa menos de 5MB e não consome quase nada de memória.",
  },
  {
    q: "Tem aplicativo para iPhone (iOS)?",
    a: "Sim, funciona perfeitamente no iPhone! Motoristas com iOS acessam o Van360 com total performance pelo navegador, enquanto o app nativo está sendo desenvolvido para a App Store.",
  },
  {
    q: "Quanto vou pagar depois dos 15 dias?",
    a: `Se você entrar agora como fundador, paga R$ ${originalFormatted}/mês — para sempre, sem reajuste. Se preferir não continuar, é só não assinar. Sem multa, sem burocracia.`,
  },
  {
    q: "Como funciona o programa de indicações?",
    a: "É muito simples! Dentro do aplicativo você terá acesso ao seu link exclusivo de convite. Compartilhe esse link com seus colegas. Quando eles se cadastrarem e efetuarem a primeira assinatura, você ganha meses gratuitos (sem limites de indicações) e o seu amigo indicado ainda recebe um desconto especial na assinatura. Ambos ganham!",
  },
];

const soonItems = [
  {
    emoji: "🗺️",
    title: "Rotas e itinerários",
    desc: "Monte suas rotas, organize os pontos de embarque e otimize seu trajeto diário.",
  },
  {
    emoji: "🚍",
    title: "Fretamentos e Viagens",
    desc: "Organize passeios e excursões. Registre suas viagens extras, controle quem já pagou e acompanhe quanto você faturou no mês.",
  },
  {
    emoji: "👨‍👩‍👦",
    title: "App para os pais",
    desc: "O responsável acompanha tudo pelo celular — parcelas, contrato, dados do filho. Menos WhatsApp pra você.",
  },
  {
    emoji: "💸",
    title: "Pagamento via Pix com baixa automática",
    desc: "O pai paga direto pelo app e o sistema dá baixa sozinho — sem você precisar marcar nada manualmente.",
  },
];

const schemaJson = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Van360",
    "description": "Organize passageiros, parcelas, contratos e recibos. Automatize a cobrança de parcelas pelo WhatsApp.",
    "applicationCategory": "BusinessApplication",
    "operatingSystem": "Android, Web",
    "url": "https://van360.com.br",
    "offers": {
      "@type": "Offer",
      "price": originalVal.toFixed(2),
      "priceCurrency": "BRL",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map((item) => ({
      "@type": "Question",
      "name": item.q,
      "acceptedAnswer": {
        "@type": "Answer",
        "text": item.a,
      },
    })),
  },
]);
---

<Layout
  title="Van360 — App para Van Escolar e Gestão de Passageiros"
  description="Gerencie passageiros, parcelas, contratos e recibos. Automatize a cobrança de parcelas pelo WhatsApp e organize sua van escolar. Teste grátis por 15 dias."
>
  <script type="application/ld+json" slot="head" set:html={schemaJson} />
  <div
    class="min-h-screen bg-white text-[#1a1a1a] font-['Inter',sans-serif] overflow-x-hidden scroll-smooth selection:bg-amber-200"
  >
    <HeaderLP />
    <main>

    <style is:global>
      .lp-reveal {
        opacity: 0;
        transform: translateY(24px);
        transition:
          opacity 0.6s ease,
          transform 0.6s ease;
      }
      .lp-visible {
        opacity: 1;
        transform: translateY(0);
      }
      @keyframes lp-countUp {
        from {
          opacity: 0;
          transform: translateY(12px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }
      @keyframes lp-cta-glow {
        0%,
        100% {
          box-shadow: 0 2px 8px rgba(245, 158, 11, 0.35);
        }
        50% {
          box-shadow: 0 4px 20px rgba(245, 158, 11, 0.5);
        }
      }
      .lp-cta-glow {
        animation: lp-cta-glow 2.5s ease-in-out infinite;
      }
      .hide-scrollbar::-webkit-scrollbar {
        display: none;
      }
      .hide-scrollbar {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
      @media (min-width: 768px) {
        .hero-phone {
          transform: perspective(800px) rotateY(-8deg);
          transition: transform 0.4s ease;
        }
        .hero-phone:hover {
          transform: perspective(800px) rotateY(-2deg);
        }
        .feature-phone {
          transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
        .feature-phone:hover {
          transform: translateY(-12px) scale(1.03);
        }
      }
    </style>

    {/* Spacer navbar fixed */}
    <div class="h-14 md:h-16"></div>

    {/* ══════════ HERO SECTION ══════════ */}
    <section
      class="pt-12 md:pt-16 pb-14 md:pb-20 bg-gradient-to-b from-[#f0f4f8] to-white"
    >
      <div class="max-w-[1120px] mx-auto px-5">
        <div
          class="flex flex-col md:grid md:grid-cols-[60%_40%] items-center gap-10 md:gap-8"
        >
          {/* Texto */}
          <div class="text-center md:text-left order-1 flex flex-col">
            <div
              class="inline-flex items-center justify-center md:justify-start gap-1.5 bg-[#1a3a5c]/10 px-3.5 py-1 sm:py-1.5 rounded-full text-[#1a3a5c] font-bold text-[11px] sm:text-[11.5px] uppercase tracking-wider mb-5 mx-auto md:mx-0 w-fit"
            >
              App para motorista escolar
            </div>
            <h1
              class="text-[clamp(1.8rem,5vw,3rem)] sm:text-[clamp(1.9rem,5vw,3rem)] font-black leading-[1.12] tracking-tight mb-4 text-[#1a1a1a]"
            >
              <span class="text-[#f59e0b]">Chega de planilha e caderno.</span>
              <br />
              <span class="text-[#1a3a5c]">Chega de cobrar pai por pai.</span>
            </h1>
            <p
              class="text-[clamp(1.05rem,2.5vw,1.2rem)] text-slate-500 max-w-[520px] md:mx-0 mx-auto mb-8 leading-relaxed"
            >
              O Van360 organiza seus passageiros, cobra automático pelo
              WhatsApp e emite recibo — tudo num só lugar.
            </p>

            {/* CTA */}
            <div class="flex flex-col items-center md:items-start gap-3">
              <a
                href={LINKS.APP_REGISTER_URL}
                class="lp-cta-glow inline-flex items-center justify-center bg-[#f59e0b] hover:bg-[#d97706] text-[#1a1a1a] font-bold text-base px-8 py-4 rounded-lg hover:scale-[1.02] hover:-translate-y-0.5 transition-all min-h-[44px] w-full sm:w-auto shadow-lg text-center"
              >
                Testar grátis por 15 dias
              </a>

              {/* Badges / Plataformas - DESKTOP APENAS */}
              <div class="hidden md:flex flex-row items-center gap-4 mt-3">
                <a
                  href={LINKS.PLAY_STORE_URL}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex hover:-translate-y-0.5 transition-transform shrink-0"
                  aria-label="Baixar Van360 na Play Store"
                >
                  <img
                    src={LINKS.PLAY_STORE_BADGE_URL}
                    alt="Disponível no Google Play"
                    width={189}
                    height={56}
                    class="h-14 object-contain"
                  />
                </a>
                <div
                  class="flex items-center gap-1.5 text-slate-400 border-l border-slate-200 pl-4 h-10"
                >
                  <Smartphone class="w-4 h-4" />
                  <span
                    class="text-[12px] font-medium leading-tight text-slate-400"
                    >Funciona também no iPhone<br />(pelo navegador)</span
                  >
                </div>
              </div>
            </div>

            {/* Mockup — SÓ MOBILE */}
            <div class="flex justify-center md:hidden relative mt-10 mb-8">
              <div class="max-w-[320px] sm:max-w-[360px] w-full relative">
                {/* WhatsApp Balloon */}
                <div
                  class="absolute bg-white/95 backdrop-blur-md rounded-xl md:rounded-2xl shadow-[0_8px_30px_rgb(0,0,0,0.12)] p-2 md:p-3 border border-slate-100 max-w-[150px] md:max-w-[220px] z-20 pointer-events-none -top-4 left-0 sm:-left-4"
                  style="animation: lp-countUp .6s cubic-bezier(0.34, 1.56, 0.64, 1) 1s both;"
                >
                  <div
                    class="flex items-center gap-1.5 md:gap-2 mb-1 md:mb-1.5"
                  >
                    <div
                      class="w-3.5 h-3.5 md:w-5 md:h-5 rounded-full bg-[#25D366]/15 flex items-center justify-center flex-shrink-0"
                    >
                      <svg
                        viewBox="0 0 24 24"
                        fill="currentColor"
                        class="w-2 h-2 md:w-3 md:h-3 text-[#25D366]"
                        xmlns="http://www.w3.org/2000/svg"
                      >
                        <path
                          d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
                        ></path>
                      </svg>
                    </div>
                    <div
                      class="text-[0.55rem] md:text-[0.65rem] font-bold text-slate-400 uppercase tracking-wider"
                    >
                      WhatsApp enviado
                    </div>
                  </div>
                  <div
                    class="text-[0.65rem] md:text-[0.75rem] text-[#1a3a5c] font-medium leading-snug"
                  >
                    A parcela de julho do Enzo vence hoje.
                  </div>
                </div>
                <Image
                  src={mockup3dHome}
                  alt="App para controle de parcelas da van escolar rodando no celular"
                  loading="eager"
                  fetchpriority="high"
                  class="w-full h-auto drop-shadow-xl"
                />
              </div>
            </div>

            {/* Benefícios (Desktop: Horizontal com bolinhas) */}
            <div
              class="hidden md:flex items-center flex-wrap gap-3 mt-6 text-[#1a3a5c]/80 font-medium text-[13.5px]"
            >
              <div class="flex items-center gap-1.5">
                <Check class="w-4 h-4 text-[#f59e0b]" />
                <span>Passageiros ilimitados</span>
              </div>
              <div class="w-1 h-1 rounded-full bg-slate-300"></div>
              <div class="flex items-center gap-1.5">
                <Check class="w-4 h-4 text-[#f59e0b]" />
                <span>Configure em 5 minutos</span>
              </div>
              <div class="w-1 h-1 rounded-full bg-slate-300"></div>
              <div class="flex items-center gap-1.5">
                <Check class="w-4 h-4 text-[#f59e0b]" />
                <span>Celular ou computador</span>
              </div>
            </div>

            {/* Benefícios (Mobile: Grid de Features) */}
            <div
              class="grid grid-cols-3 gap-2 md:hidden mt-2 mb-8 px-5 w-full max-w-[360px] mx-auto"
            >
              <div class="flex flex-col items-center text-center gap-1.5">
                <div
                  class="w-8 h-8 rounded-full bg-[#f59e0b]/10 flex items-center justify-center"
                >
                  <Users class="w-4 h-4 text-[#d97706]" />
                </div>
                <span
                  class="text-[10.5px] font-semibold text-[#1a3a5c] leading-[1.15]"
                  >Passageiros<br />ilimitados</span
                >
              </div>
              <div
                class="flex flex-col items-center text-center gap-1.5 border-x border-slate-100 px-1"
              >
                <div
                  class="w-8 h-8 rounded-full bg-[#f59e0b]/10 flex items-center justify-center"
                >
                  <Clock class="w-4 h-4 text-[#d97706]" />
                </div>
                <span
                  class="text-[10.5px] font-bold text-[#1a3a5c] leading-[1.15]"
                  >Configure<br />em 5 min</span
                >
              </div>
              <div class="flex flex-col items-center text-center gap-1.5">
                <div
                  class="w-8 h-8 rounded-full bg-[#f59e0b]/10 flex items-center justify-center"
                >
                  <Smartphone class="w-4 h-4 text-[#d97706]" />
                </div>
                <span
                  class="text-[10.5px] font-bold text-[#1a3a5c] leading-[1.15]"
                  >Celular ou<br />computador</span
                >
              </div>
            </div>

            {
              /* Badges Plataforma - MOBILE APENAS (Carregados via JS cliente para fidelidade) */
            }
            <div
              id="badge-ios-mobile"
              class="hidden md:hidden mt-6 mb-2 bg-blue-50/60 border border-blue-100 px-5 py-4 rounded-2xl text-center flex flex-col items-center gap-2 max-w-[320px] mx-auto"
            >
              <div class="p-2 bg-blue-100/80 text-blue-600 rounded-full mb-1">
                <Smartphone class="w-6 h-6" />
              </div>
